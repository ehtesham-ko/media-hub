@import "tailwindcss" source(none);
@source "../src";
@import "tw-animate-css";

@custom-variant dark (&:is(.dark *));

@theme {
  --font-serif: "Noto Serif Telugu", serif;
  --font-sans: "DM Sans", sans-serif;
}

/*
 * Design system definition.
 *
 * The @theme inline block maps CSS custom properties to Tailwind utility
 * classes (e.g. --color-primary -> bg-primary, text-primary).
 *
 * The :root and .dark blocks define the actual color values using oklch.
 * All colors MUST use oklch format.
 *
 * To add a new semantic color:
 * 1. Add the variable to :root (light value) and .dark (dark value)
 * 2. Register it in @theme inline as --color-<name>: var(--<name>)
 */

@theme inline {
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);
  --radius-2xl: calc(var(--radius) + 8px);
  --radius-3xl: calc(var(--radius) + 12px);
  --radius-4xl: calc(var(--radius) + 16px);
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --color-ring-offset-background: var(--background);
  --color-chart-1: var(--chart-1);
  --color-chart-2: var(--chart-2);
  --color-chart-3: var(--chart-3);
  --color-chart-4: var(--chart-4);
  --color-chart-5: var(--chart-5);
  --color-sidebar: var(--sidebar);
  --color-sidebar-foreground: var(--sidebar-foreground);
  --color-sidebar-primary: var(--sidebar-primary);
  --color-sidebar-primary-foreground: var(--sidebar-primary-foreground);
  --color-sidebar-accent: var(--sidebar-accent);
  --color-sidebar-accent-foreground: var(--sidebar-accent-foreground);
  --color-sidebar-border: var(--sidebar-border);
  --color-sidebar-ring: var(--sidebar-ring);
}

:root {
  --radius: 0.625rem;
  --background: oklch(0.98 0.01 80);
  --foreground: oklch(0.22 0.02 50);
  --card: oklch(1 0 0);
  --card-foreground: oklch(0.22 0.02 50);
  --popover: oklch(1 0 0);
  --popover-foreground: oklch(0.22 0.02 50);
  --primary: oklch(0.55 0.2 265);
  --primary-foreground: oklch(0.99 0.01 85);
  --secondary: oklch(0.95 0.02 70);
  --secondary-foreground: oklch(0.32 0.06 50);
  --muted: oklch(0.95 0.012 70);
  --muted-foreground: oklch(0.5 0.03 50);
  --accent: oklch(0.45 0.12 195);
  --accent-foreground: oklch(0.99 0.01 85);
  --destructive: oklch(0.577 0.245 27.325);
  --destructive-foreground: oklch(0.984 0.003 247.858);
  --border: oklch(0.9 0.012 70);
  --input: oklch(0.9 0.012 70);
  --ring: oklch(0.55 0.2 265);
  --chart-1: oklch(0.55 0.2 265);
  --chart-2: oklch(0.45 0.12 195);
  --chart-3: oklch(0.55 0.09 145);
  --chart-4: oklch(0.6 0.12 250);
  --chart-5: oklch(0.65 0.13 300);
  --sidebar: oklch(0.13 0.04 265);
  --sidebar-foreground: oklch(0.95 0.01 85);
  --sidebar-primary: oklch(0.55 0.2 265);
  --sidebar-primary-foreground: oklch(0.18 0.02 50);
  --sidebar-accent: oklch(0.26 0.03 50);
  --sidebar-accent-foreground: oklch(0.98 0.01 85);
  --sidebar-border: oklch(0.3 0.03 50);
  --sidebar-ring: oklch(0.55 0.2 265);
}

.dark {
  --background: oklch(0.14 0.015 50);
  --foreground: oklch(0.95 0.01 80);
  --card: oklch(0.19 0.018 50);
  --card-foreground: oklch(0.95 0.01 80);
  --popover: oklch(0.19 0.018 50);
  --popover-foreground: oklch(0.95 0.01 80);
  --primary: oklch(0.68 0.2 265);
  --primary-foreground: oklch(0.12 0.02 50);
  --secondary: oklch(0.24 0.025 50);
  --secondary-foreground: oklch(0.90 0.01 80);
  --muted: oklch(0.24 0.025 50);
  --muted-foreground: oklch(0.62 0.04 65);
  --accent: oklch(0.55 0.14 195);
  --accent-foreground: oklch(0.99 0.01 85);
  --destructive: oklch(0.65 0.22 27);
  --destructive-foreground: oklch(0.98 0.01 80);
  --border: oklch(0.28 0.025 50);
  --input: oklch(0.28 0.025 50);
  --ring: oklch(0.72 0.18 52);
  --chart-1: oklch(0.72 0.18 52);
  --chart-2: oklch(0.55 0.14 195);
  --chart-3: oklch(0.62 0.10 145);
  --chart-4: oklch(0.65 0.14 250);
  --chart-5: oklch(0.68 0.15 300);
  --sidebar: oklch(0.10 0.03 265);
  --sidebar-foreground: oklch(0.95 0.01 85);
  --sidebar-primary: oklch(0.72 0.18 52);
  --sidebar-primary-foreground: oklch(0.11 0.015 50);
  --sidebar-accent: oklch(0.20 0.02 50);
  --sidebar-accent-foreground: oklch(0.95 0.01 85);
  --sidebar-border: oklch(0.22 0.02 50);
  --sidebar-ring: oklch(0.72 0.18 52);
}

@layer base {
  * {
    border-color: var(--color-border);
  }

  body {
    background-color: var(--color-background);
    color: var(--color-foreground);
  }
}

@keyframes borderSpin {
  to {
    --angle: 360deg;
  }
}

@property --angle {
  syntax: "<angle>";
  initial-value: 0deg;
  inherits: false;
}

@utility dropzone-glow {
  background:
    linear-gradient(var(--card), var(--card)) padding-box,
    conic-gradient(from var(--angle), var(--primary), var(--accent), var(--primary)) border-box;
  border: 2px solid transparent;
  animation: borderSpin 4s linear infinite;
}

@keyframes shine {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}

@layer components {
  .btn-shine {
    background-image: linear-gradient(
      110deg,
      var(--primary) 0%,
      color-mix(in oklab, var(--primary) 70%, white) 50%,
      var(--primary) 100%
    );
    background-size: 200% auto;
  }
  .btn-shine:hover {
    animation: shine 1.2s linear infinite;
  }
  .nav-underline::after {
    content: "";
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.35rem;
    height: 2px;
    background: var(--primary);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }
  .nav-underline:hover::after {
    transform: scaleX(1);
  }
  .card-hover {
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .card-hover:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px -8px color-mix(in oklab, var(--primary) 20%, transparent);
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.4s ease both;
  }
  .pulse-ring {
    animation: pulse-ring 2s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite;
  }
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-6px); }
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeInLeft {
  from { opacity: 0; transform: translateX(-20px); }
  to { opacity: 1; transform: translateX(0); }
}
@keyframes fadeInRight {
  from { opacity: 0; transform: translateX(20px); }
  to { opacity: 1; transform: translateX(0); }
}
@keyframes pulse-ring {
  0% { box-shadow: 0 0 0 0 color-mix(in oklab, var(--primary) 40%, transparent); }
  70% { box-shadow: 0 0 0 8px transparent; }
  100% { box-shadow: 0 0 0 0 transparent; }
}
